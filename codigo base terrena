  Serial.println("\n");
  Serial.println("+========================================+");
  Serial.println("|         ESTACION TERRENA               |");
  Serial.println("|      ESP32-S3 + RFM95W 915MHz          |");
  Serial.println("+========================================+");
  Serial.println("| COMANDOS DISPONIBLES:                  |");
  Serial.println("+========================================+");
  Serial.println("| 1 - Servo 0deg (desplegar)             |");
  Serial.println("| 2 - Servo 45deg (armar)                |");
  Serial.println("| 3 - Calibrar BMP180 (altimetro)        |");
  Serial.println("| 4 - Calibrar IMU (giroscopio)          |");
  Serial.println("| 5 - Estado GPS                         |");
  Serial.println("| 6 - Telemetria (20 lecturas @ 2Hz)     |");
  Serial.println("| 7 - INICIAR VUELO                      |");
  Serial.println("| 8 - Ver datos CSV                      |");
  Serial.println("| 9 - Borrar CSV                         |");
  Serial.println("| p - Parar telemetria                   |");
  Serial.println("| m - Mostrar este menu                  |");
  Serial.println("+========================================+");
