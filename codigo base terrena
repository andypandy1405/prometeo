// ===== ESTACIÓN TERRENA - ESP32-S3 + RFM95W 915MHz =====
// ===== RECEPCIÓN DE TELEMETRÍA Y ENVÍO DE COMANDOS =====
#include <Arduino.h>
#include <LoRa.h>
#include <SPI.h>

/************ PINES LORA RFM95W 915MHz ************/
#define LORA_CS    10
#define LORA_RST   8
#define LORA_DIO0  9
#define LORA_SCK   12
#define LORA_MISO  13
#define LORA_MOSI  11
#define LORA_BAND  915E6  // 915 MHz

/************ CONFIGURACIÓN ************/
bool lora_ok = false;
unsigned long lastPacketTime = 0;
int packetsReceived = 0;
int packetsMissed = 0;
unsigned long sessionStart = 0;

/************ ESTADÍSTICAS ************/
struct Stats {
  int rssi_min = 0;
  int rssi_max = -200;
  float rssi_avg = 0;
  float snr_min = -20;
  float snr_max = 20;
  int packet_count = 0;
} stats;

/************ FUNCIONES ************/
void sendCommand(char cmd){
  if(!lora_ok){
    Serial.println("[ERROR] LoRa no disponible");
    return;
  }
  
  Serial.println("\n[ENVIANDO] Comando: '" + String(cmd) + "'");
  
  LoRa.beginPacket();
  LoRa.print(cmd);
  
  if(LoRa.endPacket()){
    Serial.println("[OK] Comando enviado exitosamente");
  } else {
    Serial.println("[ERROR] Fallo al enviar comando");
  }
}

