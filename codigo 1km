        Serial.print("| Presion base: "); Serial.print(alt0, 2); Serial.println(" m (abs)");
        Serial.println("+========================================+\n");
        queueLoraMessage("BMP180 calibrado: 0.00m");
      } else {
        Serial.println("ERROR: No se pudo calibrar BMP180");
        queueLoraMessage("ERROR: No se pudo calibrar BMP180");
      }
      break;
    }

    case '4':
      calibrateIMU();
      break;

    case '5': {
      String msg = "GPS: ";
      if(gps.location.isValid()){
        msg += String(gps.location.lat(), 6) + "," + String(gps.location.lng(), 6);
