}

/*** MPU6050 ***/
bool readMPU(int16_t &ax, int16_t &ay, int16_t &az){
  for(int retry = 0; retry < 3; retry++){
    Wire.beginTransmission(mpu_addr);
    Wire.write(0x3B);
    byte error = Wire.endTransmission(false);
    if(error == 0){
      Wire.setTimeout(50);
      if(Wire.requestFrom((int)mpu_addr, 6) == 6){
        ax = (Wire.read()<<8) | Wire.read();
        ay = (Wire.read()<<8) | Wire.read();
        az = (Wire.read()<<8) | Wire.read();
        return true;
      }
    }
    delay(5);
  }
  return false;
}

bool initMPU(uint8_t addr){
  Wire.beginTransmission(addr);
  Wire.write(0x6B);
  Wire.write(0x00);
  if(Wire.endTransmission() != 0) return false;
  Wire.beginTransmission(addr);
  Wire.write(0x1C);
  Wire.write(0x18);  // ±16g
  return (Wire.endTransmission() == 0);
}

void calcAngles(int16_t ax, int16_t ay, int16_t az, float &pitch, float &roll){
  float x = ax / 16384.0f;
  float y = ay / 16384.0f;
  float z = az / 16384.0f;
  roll  = atan2(y, z) * 57.3 - roll_offset;
  pitch = atan2(-x, sqrt(y*y + z*z)) * 57.3 - pitch_offset;
}

// FIX #1: aceleración axial para confirmar lanzamiento
float readIMUAccelG(){
  int16_t ax, ay, az;
  if(!mpu_ok || !readMPU(ax, ay, az)) return 0.0f;
  return fabs(az / 2048.0f);
}

// FIX #8: aceleración real del IMU en m/s²
float readIMUAccelMs2(){
  int16_t ax, ay, az;
  if(!mpu_ok || !readMPU(ax, ay, az)) return 0.0f;
  return (az / 2048.0f) * 9.81f;
}

void calibrateIMU(){
  if(!mpu_ok){
    Serial.println("ERROR: MPU6050 no disponible");
    queueLoraMessage("ERROR: IMU no disponible");
    return;
  }
  Serial.println("Calibrando IMU...");
  queueLoraMessage("Calibrando IMU...");
  delay(1000);

  float pitch_sum = 0, roll_sum = 0;
  int samples = 100, validSamples = 0;

  for(int i = 0; i < samples; i++){
    int16_t ax, ay, az;
    if(readMPU(ax, ay, az)){
      float x = ax/16384.0f, y = ay/16384.0f, z = az/16384.0f;
      pitch_sum += atan2(-x, sqrt(y*y + z*z)) * 57.3;
      roll_sum  += atan2(y, z) * 57.3;
      validSamples++;
    }
    delay(10);
  }

  if(validSamples > 50){
    pitch_offset = pitch_sum / validSamples;
    roll_offset  = roll_sum  / validSamples;
    imuCalibrated = true;
    Serial.println("IMU calibrado OK - P:" + String(pitch_offset,2) + " R:" + String(roll_offset,2));
    queueLoraMessage("IMU OK P:" + String(pitch_offset,2) + " R:" + String(roll_offset,2));
  } else {
    Serial.println("ERROR: Calibracion IMU fallida");
    queueLoraMessage("ERROR: Calibracion IMU fallida");
  }
}

/*** BMP280 ***/
float readAlt(bool &ok){
  ok = false;
  if(!bmp_ok) return NAN;
  float pressure = bmp.readPressure();
  if(pressure == 0 || isnan(pressure)) return NAN;
  float absAlt = 44330.0f * (1.0f - pow(pressure / 101325.0f, 0.1903f));
  if(isnan(absAlt)) return NAN;
  if(isnan(alt0)){
    alt0 = absAlt;
    Serial.println("Altura calibrada: 0.00 m");
    queueLoraMessage("Altura ref: " + String(alt0, 2) + "m");
  }
  ok = true;
  return absAlt - alt0;
}

/*** VELOCIDAD barométrica — FIX #8: aceleración ya no se deriva aquí ***/
void calcVelocity(float currentAlt, unsigned long currentTime, float &velocity){
  float smoothedAlt = getSmoothedAltitude(currentAlt);

  if(isnan(lastAltitude) || lastAltTime == 0){
    lastAltitude = smoothedAlt;
    lastAltTime  = currentTime;
    velocity     = 0.0;
    lastVelocity = 0.0;
    return;
  }

  float deltaTime = (currentTime - lastAltTime) / 1000.0;

  if(deltaTime < 0.05){
    velocity = lastVelocity;
    return;
  }

  float rawVelocity = (smoothedAlt - lastAltitude) / deltaTime;
  velocity = 0.5 * rawVelocity + 0.5 * lastVelocity;
  velocity = constrain(velocity, -200.0, 200.0);

  lastAltitude = smoothedAlt;
  lastVelocity = velocity;
  lastAltTime  = currentTime;
}

/*** TELEMETRIA ***/
void sendTelemetry(){
  char buffer[450];
  int pos = 0;

  if(xSemaphoreTake(telemetryMutex, pdMS_TO_TICKS(10)) == pdTRUE){
    if(telemetryOn && !flightActive)
      pos += snprintf(buffer+pos, sizeof(buffer)-pos, "[%d/20] ", telemetryCount);

    pos += snprintf(buffer+pos, sizeof(buffer)-pos,
      "[T+%lu.%01lus] [P:%.1f] [R:%.1f] [Alt:%.2fm]",
      telemetry.timestamp_ms/1000, (telemetry.timestamp_ms%1000)/100,
      telemetry.pitch, telemetry.roll, telemetry.altitude);

    if(!isnan(telemetry.velocity))
      pos += snprintf(buffer+pos, sizeof(buffer)-pos, " [Vel:%.2fm/s]", telemetry.velocity);

    // FIX #8: aceleración real del IMU
    if(telemetry.imu_accel_ms2 != 0.0f){
      float imu_g = telemetry.imu_accel_ms2 / 9.81f;
      pos += snprintf(buffer+pos, sizeof(buffer)-pos,
        " [AcelIMU:%.2fm/s2] [%.1fg]", telemetry.imu_accel_ms2, imu_g);
    }

    if(flightActive && telemetry.max_acceleration > 0){
      float max_g = telemetry.max_acceleration / 9.81f;
      pos += snprintf(buffer+pos, sizeof(buffer)-pos, " [MaxG:%.1f]", max_g);
    }

    if(flightActive && !isnan(telemetry.peak_altitude))
      pos += snprintf(buffer+pos, sizeof(buffer)-pos, " [Pico:%.2fm]", telemetry.peak_altitude);

    if(flightActive && !launchConfirmed)
      pos += snprintf(buffer+pos, sizeof(buffer)-pos, " [LAUNCH:WAIT]");

    // FIX #9: mostrar estado de armado
    if(!flightActive && armedState){
      unsigned long armRemaining = (ARM_TIMEOUT_MS - (millis() - armTime)) / 1000;
      pos += snprintf(buffer+pos, sizeof(buffer)-pos, " [ARMED:%lus]", armRemaining);
    }

    if(flightActive){
      if(!telemetry.recovery_active){
        unsigned long remaining = (LAUNCH_DELAY - (millis() - flightStartTime)) / 1000;
        pos += snprintf(buffer+pos, sizeof(buffer)-pos, " [REC:%lus]", remaining);
      } else {
        pos += snprintf(buffer+pos, sizeof(buffer)-pos, " [REC:ON]");
        if(timeoutTimerStarted && !deployedOnce.load())
          pos += snprintf(buffer+pos, sizeof(buffer)-pos, " [TO:%us]", telemetry.timeout_remaining_s);
      }
    }

    if(telemetry.gps_sats > 0){
      pos += snprintf(buffer+pos, sizeof(buffer)-pos, " [Sats:%d]", telemetry.gps_sats);
      if(!isnan(telemetry.gps_lat) && !isnan(telemetry.gps_lng))
        pos += snprintf(buffer+pos, sizeof(buffer)-pos,
          " [%.6f,%.6f]", telemetry.gps_lat, telemetry.gps_lng);
      if(!isnan(telemetry.gps_altitude))
        pos += snprintf(buffer+pos, sizeof(buffer)-pos, " [AltGPS:%.1fm]", telemetry.gps_altitude);
      if(!isnan(telemetry.gps_speed_kmh))
        pos += snprintf(buffer+pos, sizeof(buffer)-pos, " [VelGPS:%.1fkm/h]", telemetry.gps_speed_kmh);
      if(!isnan(telemetry.gps_hdop))
        pos += snprintf(buffer+pos, sizeof(buffer)-pos, " [HDOP:%.1f]", telemetry.gps_hdop);
    } else {
      pos += snprintf(buffer+pos, sizeof(buffer)-pos, " [GPS:SIN SENAL]");
    }

    xSemaphoreGive(telemetryMutex);
  }

  Serial.println(buffer);
  queueLoraMessage(buffer);
}

/*** RECUPERACION ***/
// FIX #10: compare_exchange_strong garantiza ejecución única sin deshabilitar interrupciones
void deploy(const String &reason){
  bool expected = false;
  if(!deployedOnce.compare_exchange_strong(expected, true)) return;

  myServo.write(0);

  Serial.println("*** PARACAIDAS DESPLEGADO ***");
  Serial.println("RAZON: " + reason);
  Serial.println("T+" + String(millis()/1000) + "s | Servo->0deg");
  if(maxAcceleration > 0){
    float max_g = maxAcceleration / 9.81;
    Serial.println("MaxG IMU: " + String(max_g, 1) + "g");
  }

  queueLoraMessage("*** PARACAIDAS DESPLEGADO ***");
  queueLoraMessage("RAZON: " + reason);
  queueLoraMessage("T+" + String(millis()/1000) + "s | SERVO->0deg");

  if(xSemaphoreTake(telemetryMutex, pdMS_TO_TICKS(10)) == pdTRUE){
    telemetry.parachute_deployed = true;
    xSemaphoreGive(telemetryMutex);
  }
}

/*** COMANDOS ***/
void execCmd(char c){
  switch(c){
    case '1': setServo(0);  queueLoraMessage("Servo -> 0deg OK");  break;
    case '2': setServo(45); queueLoraMessage("Servo -> 45deg OK"); break;

    case '3': {
      if(!bmp_ok){ queueLoraMessage("ERROR: BMP280 no disponible"); break; }
      alt0 = NAN; lastAltitude = NAN; lastAltTime = 0; lastVelocity = 0.0;
      altBufferIndex = 0; altBufferFull = false;
      for(int i = 0; i < ALT_BUFFER_SIZE; i++) altitudeBuffer[i] = 0.0;
      maxAcceleration = 0.0; maxImuAccelMs2 = 0.0;
      bool ok; readAlt(ok);
      queueLoraMessage(ok ? "BMP280 calibrado: 0.00m" : "ERROR: No se pudo calibrar BMP280");
      break;
    }

    case '4': calibrateIMU(); break;

    case '5': {
      String msg = "GPS: ";
      if(gps.location.isValid()){
        msg += String(gps.location.lat(), 6) + "," + String(gps.location.lng(), 6);
        msg += " Sats:" + String(gps.satellites.value());
        if(gps.altitude.isValid()) msg += " Alt:" + String(gps.altitude.meters(), 1) + "m";
        if(gps.speed.isValid())    msg += " Vel:" + String(gps.speed.kmph(), 1) + "km/h";
        if(gps.hdop.isValid())     msg += " HDOP:" + String(gps.hdop.hdop(), 2);
      } else {
        msg += "Sin senal (" + String(gps.satellites.value()) + " sats)";
      }
      Serial.println(msg);
      queueLoraMessage(msg);
      break;
    }

    case '6':
      telemetryOn = true; flightActive = false; telemetryCount = 0;
      alt0 = NAN; lastAltitude = NAN; lastAltTime = 0; lastVelocity = 0.0;
      altBufferIndex = 0; altBufferFull = false;
      for(int i = 0; i < ALT_BUFFER_SIZE; i++) altitudeBuffer[i] = 0.0;
      maxAcceleration = 0.0; maxImuAccelMs2 = 0.0;
      Serial.println("TELEMETRIA ON (20 @ 2Hz)");
      queueLoraMessage("Telemetria ON (20 @ 2Hz)");
      break;

    // FIX #9: paso 1 — armar
    case 'a': case 'A':
      if(!bmp_ok || !mpu_ok){
        Serial.println("ERROR: Sensores no disponibles para armar");
        queueLoraMessage("ERROR ARM: BMP280=" + String(bmp_ok) + " IMU=" + String(mpu_ok));
        break;
      }
      if(!imuCalibrated){
        Serial.println("ERROR: IMU no calibrado — usa comando 4 primero");
        queueLoraMessage("ERROR ARM: IMU no calibrado");
        break;
      }
      armedState = true;
      armTime = millis();
      Serial.println("*** SISTEMA ARMADO — envia '7' en " + String(ARM_TIMEOUT_MS/1000) + "s para lanzar ***");
      queueLoraMessage("*** ARMADO — confirma con '7' en " + String(ARM_TIMEOUT_MS/1000) + "s ***");
      break;

    // FIX #9: paso 2 — lanzar solo si armado y dentro del timeout
    case '7':
      if(!armedState){
        Serial.println("RECHAZADO: Sistema no armado — usa 'A' primero");
        queueLoraMessage("RECHAZADO: Armar primero con 'A'");
        break;
      }
      if(millis() - armTime > ARM_TIMEOUT_MS){
        armedState = false;
        Serial.println("RECHAZADO: Timeout de armado — rearma con 'A'");
        queueLoraMessage("RECHAZADO: Timeout armado — rearma con 'A'");
        break;
      }
      armedState = false;
      flightActive = true; telemetryOn = false;
      deployedOnce.store(false);
      telemetryCount = 0;
      launchConfirmed = false;
      altitudeTriggerCount = 0;
      alt0 = NAN; peakAlt = NAN; lastAltitude = NAN; lastAltTime = 0; lastVelocity = 0.0;
      altBufferIndex = 0; altBufferFull = false;
      for(int i = 0; i < ALT_BUFFER_SIZE; i++) altitudeBuffer[i] = 0.0;
      timeoutTimerStarted = false; timeoutStartTime = 0;
      maxAcceleration = 0.0; maxImuAccelMs2 = 0.0;
      if(xSemaphoreTake(telemetryMutex, pdMS_TO_TICKS(10)) == pdTRUE){
        memset(&telemetry, 0, sizeof(telemetry));
        xSemaphoreGive(telemetryMutex);
      }
      flightStartTime = millis();
      Serial.println("VUELO INICIADO | 10Hz sensores | 2Hz LoRa | TO:16s@7m | CAIDA:10m");
      queueLoraMessage("VUELO v4 | 10Hz/2Hz | todos los FIX activos");
      queueLoraMessage("TIMEOUT: 16s @ 7m | CAIDA: 10m");
      break;

    case 'p': case 'P':
      telemetryOn = false; flightActive = false;
      timeoutTimerStarted = false; armedState = false;
      Serial.println("TELEMETRIA DETENIDA");
      queueLoraMessage("Telemetria STOP");
      break;

    case 'm': case 'M':
      Serial.println("\n=== MENU ===");
      Serial.println("1) Servo 0deg");
      Serial.println("2) Servo 45deg");
      Serial.println("3) Calibrar BMP280");
      Serial.println("4) Calibrar IMU");
      Serial.println("5) GPS");
      Serial.println("6) Telemetria (20 @ 2Hz)");
      Serial.println("A) ARMAR sistema");
      Serial.println("7) LANZAR (solo si armado)");
      Serial.println("p) Parar");
      Serial.println("============");
      queueLoraMessage("Menu OK");
      break;

    default: break;
  }
}

//==============================================================================
// TASK CORE 0: SENSORES + RECUPERACION — 10Hz
//==============================================================================
void sensorTask(void *parameter){
  TickType_t xLastWakeTime = xTaskGetTickCount();
  const TickType_t xFrequency = pdMS_TO_TICKS(SENSOR_INTERVAL);
  Serial.println("[CORE 0] Sensores @ 10Hz");

  while(true){
    vTaskDelayUntil(&xLastWakeTime, xFrequency);
    if(!telemetryOn && !flightActive) continue;

    float pitch = NAN, roll = NAN, altRel = NAN, velocity = NAN;
    bool altOk = false;

    if(mpu_ok && imuCalibrated){
      int16_t ax, ay, az;
      if(readMPU(ax, ay, az)) calcAngles(ax, ay, az, pitch, roll);
    }

    // FIX #8: aceleración real del IMU
    float imuAccelMs2 = 0.0f;
    if(mpu_ok){
      imuAccelMs2 = readIMUAccelMs2();
      if(flightActive && fabs(imuAccelMs2) > maxImuAccelMs2){
        maxImuAccelMs2 = fabs(imuAccelMs2);
        maxAcceleration = maxImuAccelMs2;
      }
    }

    altRel = readAlt(altOk);
    if(altOk && !isnan(altRel))
      calcVelocity(altRel, millis(), velocity);

    // FIX #1: confirmar lanzamiento con IMU
    if(flightActive && !launchConfirmed && mpu_ok){
      float accelG = readIMUAccelG();
      if(accelG >= LAUNCH_ACCEL_THRESHOLD_G){
        launchConfirmed = true;
        Serial.println("*** LAUNCH CONFIRMED IMU: " + String(accelG, 2) + "g ***");
        queueLoraMessage("*** LAUNCH CONFIRMED IMU: " + String(accelG, 1) + "g ***");
      }
    }

    // FIX #9: verificar timeout de armado
    if(armedState && (millis() - armTime > ARM_TIMEOUT_MS)){
      armedState = false;
      Serial.println("Timeout de armado expirado");
      queueLoraMessage("ARM timeout — sistema desarmado");
    }

    if(xSemaphoreTake(telemetryMutex, pdMS_TO_TICKS(5)) == pdTRUE){
      telemetry.timestamp_ms     = millis();
      telemetry.pitch            = pitch;
      telemetry.roll             = roll;
      telemetry.altitude         = altRel;
      telemetry.velocity         = velocity;
      telemetry.imu_accel_ms2    = imuAccelMs2;
      telemetry.acceleration     = imuAccelMs2;
      telemetry.max_acceleration = maxAcceleration;

      // FIX #1: recoveryActive requiere IMU confirmado + tiempo transcurrido
      bool recoveryActive = flightActive
                            && launchConfirmed
                            && (millis() - flightStartTime >= LAUNCH_DELAY);

      telemetry.recovery_active = recoveryActive;
      xSemaphoreGive(telemetryMutex);

      if(recoveryActive && altOk && !isnan(altRel)){

        // FIX #2: histéresis 3 muestras + velocidad positiva
        if(!timeoutTimerStarted){
          if(altRel >= TIMEOUT_ALTITUDE_TRIGGER){
            altitudeTriggerCount++;
          } else {
            altitudeTriggerCount = 0;
          }

          if(altitudeTriggerCount >= ALTITUDE_HYSTERESIS_COUNT){
            bool ascending = (!isnan(velocity) && velocity > 0.0f);
            if(ascending){
              timeoutTimerStarted = true;
              timeoutStartTime = millis();
              Serial.println("*** TIMEOUT START @ " + String(altRel,2) + "m - 16s *** ["
                             + String(altitudeTriggerCount) + " muestras, vel+"
                             + String(velocity,1) + "m/s]");
              queueLoraMessage("*** TO START @ " + String(altRel,1) + "m [IMU+BARO OK] ***");
            } else {
              altitudeTriggerCount = 0;
              Serial.println("ALERTA: Alt " + String(altRel,1) + "m vel=" + String(velocity,1) + "m/s — no es ascenso");
              queueLoraMessage("ALERTA: Alt " + String(altRel,1) + "m vel=" + String(velocity,1) + "m/s — esperando ascenso");
            }
          }
        }

        bool deployed = deployedOnce.load();

        if(timeoutTimerStarted && !deployed){
          unsigned long elapsedTimeout = millis() - timeoutStartTime;
          telemetry.timeout_remaining_s = (TIMEOUT_DURATION - elapsedTimeout) / 1000;
          if(elapsedTimeout >= TIMEOUT_DURATION)
            deploy("TIMEOUT 16s @ " + String(altRel,1) + "m | Pico:" + String(peakAlt,1) + "m");
        }

        if(isnan(peakAlt) || altRel > peakAlt){
          peakAlt = altRel;
          telemetry.peak_altitude = peakAlt;
        }

        if(!deployed && !isnan(peakAlt) && (peakAlt - altRel) >= DROP_FROM_PEAK_METERS)
          deploy("CAIDA 10m desde pico | Pico:" + String(peakAlt,1) + "m | Actual:" + String(altRel,1) + "m");
      }
    }

    if(telemetryOn && !flightActive){
      telemetryCount++;
      if(telemetryCount > 100){
        telemetryOn = false;
        Serial.println("[CORE 0] Telemetria completa");
        queueLoraMessage("Telemetria completa");
      }
    }
  }
}

//==============================================================================
// TASK CORE 1: COMUNICACIONES — 2Hz
//==============================================================================
void commsTask(void *parameter){
  TickType_t xLastWakeTime = xTaskGetTickCount();
  const TickType_t xFrequency = pdMS_TO_TICKS(COMMS_INTERVAL);
  Serial.println("[CORE 1] Comms @ 2Hz");

  while(true){
    vTaskDelayUntil(&xLastWakeTime, xFrequency);

    LoraMessage msg;
    while(xQueueReceive(loraQueue, &msg, 0) == pdTRUE){
      loraSendDirect(msg.text);
      vTaskDelay(pdMS_TO_TICKS(10));
    }

    // FIX #5: GPS activo durante todo el vuelo, no solo antes del despliegue
    if(flightActive){
      unsigned long gpsStart = millis();
      while(GPS_Serial.available() && (millis() - gpsStart < 50)){
        char c = GPS_Serial.read();
        gps.encode(c);
      }
      if(xSemaphoreTake(telemetryMutex, pdMS_TO_TICKS(5)) == pdTRUE){
        telemetry.gps_lat       = gps.location.isValid()   ? gps.location.lat()    : NAN;
        telemetry.gps_lng       = gps.location.isValid()   ? gps.location.lng()    : NAN;
        telemetry.gps_sats      = gps.satellites.isValid() ? gps.satellites.value(): 0;
        telemetry.gps_speed_kmh = gps.speed.isValid()      ? gps.speed.kmph()      : NAN;
        telemetry.gps_altitude  = gps.altitude.isValid()   ? gps.altitude.meters() : NAN;
        telemetry.gps_course    = gps.course.isValid()     ? gps.course.deg()      : NAN;
        telemetry.gps_hdop      = gps.hdop.isValid()       ? gps.hdop.hdop()       : NAN;
        xSemaphoreGive(telemetryMutex);
      }
    }

    if(telemetryOn || flightActive) sendTelemetry();
  }
}

/*** SETUP ***/
void setup(){
  Serial.begin(115200);
  delay(500);

  Serial.println("ESP32-S3 DUAL-CORE | 10Hz sensores | 2Hz LoRa | 20G | TO:16s@7m");
  Serial.println("v4: FIX#1+#2 criticos | FIX#5+#6 severos | FIX#8+#9+#10 importantes");

  telemetryMutex = xSemaphoreCreateMutex();
  loraMutex      = xSemaphoreCreateMutex();
  loraQueue      = xQueueCreate(LORA_QUEUE_SIZE, sizeof(LoraMessage));

  for(int i = 0; i < ALT_BUFFER_SIZE; i++) altitudeBuffer[i] = 0.0;
  altBufferIndex = 0; altBufferFull = false;

  Wire.begin(I2C_SDA_PIN, I2C_SCL_PIN);
  Wire.setClock(50000);
  Wire.setTimeout(50);

  mpu_ok = initMPU(0x68);
  if(!mpu_ok){ mpu_addr = 0x69; mpu_ok = initMPU(0x69); }
  Serial.println("MPU6050: " + String(mpu_ok ? "OK (+-16g)" : "ERROR"));
  if(mpu_ok){ delay(100); calibrateIMU(); }

  bmp_ok = bmp.begin(0x76);
  Serial.println("BMP280: " + String(bmp_ok ? "OK" : "ERROR"));
  if(bmp_ok){
    bmp.setSampling(Adafruit_BMP280::MODE_NORMAL,
                    Adafruit_BMP280::SAMPLING_X2,
                    Adafruit_BMP280::SAMPLING_X16,
                    Adafruit_BMP280::FILTER_X16,
                    Adafruit_BMP280::STANDBY_MS_63);
  }

  myServo.attach(SERVO_PIN, 500, 2500);
  setServo(45);

  GPS_Serial.begin(GPS_BAUD, SERIAL_8N1, GPS_RX_PIN, GPS_TX_PIN);
  Serial.println("GPS: OK @ 115200 baud");

  SPI.begin(LORA_SCK, LORA_MISO, LORA_MOSI, LORA_CS);
  LoRa.setPins(LORA_CS, LORA_RST, LORA_DIO0);
  pinMode(LORA_RST, OUTPUT);
  digitalWrite(LORA_RST, LOW); delay(10);
  digitalWrite(LORA_RST, HIGH); delay(100);

  lora_ok = LoRa.begin(LORA_BAND);
  if(lora_ok){
    LoRa.setTxPower(17);
    LoRa.setSpreadingFactor(7);
    LoRa.setSignalBandwidth(125E3);
    LoRa.setCodingRate4(5);
    LoRa.setSyncWord(0x12);
    Serial.println("LoRa RFM95W: OK @ 916.3MHz");
    queueLoraMessage("ESP32-S3 v4 OK | todos los FIX activos");
  } else {
    Serial.println("LoRa ERROR");
  }

  xTaskCreatePinnedToCore(sensorTask, "SensorTask", 4096, NULL, 2, NULL, 0);
  xTaskCreatePinnedToCore(commsTask,  "CommsTask",  8192, NULL, 1, NULL, 1);

  Serial.println("Tasks iniciadas. Presiona 'm' para menu.");
  Serial.println("FLUJO: A (armar) → 7 (lanzar)");
}

/*** LOOP ***/
void loop(){
  if(Serial.available()){
    char c = Serial.read();
    if(c == '\n' || c == '\r') return;
    if((c >= '1' && c <= '7') || c == 'a' || c == 'A' ||
       c == 'm' || c == 'M'  || c == 'p' || c == 'P')
      execCmd(c);
  }

  // FIX #6: parsePacket protegido con loraMutex
  if(xSemaphoreTake(loraMutex, pdMS_TO_TICKS(10)) == pdTRUE){
    int sz = LoRa.parsePacket();
    if(sz > 0){
      String msg = "";
      while(LoRa.available()) msg += (char)LoRa.read();
      xSemaphoreGive(loraMutex);
      msg.trim();
      if(msg.length() == 1){
        char c = msg.charAt(0);
        if((c >= '1' && c <= '7') || c == 'a' || c == 'A' ||
           c == 'm' || c == 'M'  || c == 'p' || c == 'P'){
          Serial.println("[LoRa RX] " + msg + " (RSSI:" + String(LoRa.packetRssi()) + ")");
          execCmd(c);
        }
      }
    } else {
      xSemaphoreGive(loraMutex);
    }
  }

  delay(10);
}
