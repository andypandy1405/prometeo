/************ BUFFER REDUCIDO PARA 20G ************/
// ⚡ CRÍTICO: Buffer reducido de 5→3 para respuesta más rápida a cambios violentos
const int ALT_BUFFER_SIZE = 3;
float altitudeBuffer[ALT_BUFFER_SIZE];
int altBufferIndex = 0;
bool altBufferFull = false;

float getSmoothedAltitude(float newAlt) {
  altitudeBuffer[altBufferIndex] = newAlt;
  altBufferIndex = (altBufferIndex + 1) % ALT_BUFFER_SIZE;
  if (altBufferIndex == 0) altBufferFull = true;
  float sum = 0;
  int count = altBufferFull ? ALT_BUFFER_SIZE : altBufferIndex;
  for(int i = 0; i < count; i++) sum += altitudeBuffer[i];
  return sum / count;
}

/************ FUNCIONES LORA ************/
void queueLoraMessage(const char* msg){
  LoraMessage lm;
  strncpy(lm.text, msg, sizeof(lm.text) - 1);
  lm.text[sizeof(lm.text) - 1] = '\0';
  xQueueSend(loraQueue, &lm, 0);
}

void queueLoraMessage(const String &msg){
  queueLoraMessage(msg.c_str());
}

void loraSendDirect(const char* msg){
  if(!lora_ok) return;
  unsigned long startTime = millis();
  LoRa.beginPacket();
  LoRa.print(msg);
  while(!LoRa.endPacket(false) && (millis() - startTime < 100)){
    delay(1);
  }
}

